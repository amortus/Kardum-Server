{
  "name": "kardum-tcg",
  "version": "1.0.0",
  "description": "Kardum - Jogo de Cartas Tático para Web e Mobile",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "serve-client": "npx -y http-server client -p 8080 -o",
    "serve-admin": "npx -y http-server admin -p 8081 -o",
    "migrate-cards": "ts-node src/scripts/migrate-cards.ts",
    "migrate-database": "ts-node src/scripts/migrate-database.ts",
    "import-cards": "ts-node src/scripts/import-cards-from-csv.ts"
  },
  "keywords": ["card-game", "tcg", "mobile", "pwa"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "socket.io": "^4.7.2",
    "redis": "^4.7.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "better-sqlite3": "^9.2.2",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
