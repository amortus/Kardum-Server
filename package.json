{
  "name": "kardum-tcg",
  "version": "1.0.0",
  "description": "Kardum - Jogo de Cartas Tático para Web e Mobile",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "serve-client": "npx -y http-server client -p 8080 -o",
    "serve-admin": "npx -y http-server admin -p 8081 -o",
    "migrate-cards": "ts-node src/scripts/migrate-cards.ts",
    "migrate-database": "ts-node src/scripts/migrate-database.ts",
    "import-cards": "ts-node src/scripts/import-cards-from-csv.ts",
    "upsert-goblin-monsters": "ts-node src/scripts/upsert-goblin-monsters.ts",
    "seed-shadowland-quests": "ts-node src/scripts/seed-shadowland-npcs-and-quests.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:regression": "vitest run tests/regression",
    "test:e2e": "vitest run tests/e2e",
    "test:security": "vitest run tests/security",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "card-game",
    "tcg",
    "mobile",
    "pwa"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "redis": "^4.7.0",
    "socket.io": "^4.7.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  }
}
