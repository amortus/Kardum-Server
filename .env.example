PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://kardum:kardum@localhost:5432/kardum

# Auth
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=30d

# Admin (set a real password — no default in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Game
ENABLE_AI=true

# Redis (optional — needed for MMO distributed mode)
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=kardum
MMO_DISTRIBUTED_STATE_ENABLED=false
MMO_SHARD_AUTHORITY_ENABLED=false
MM_MATCHMAKING_REDIS_ENABLED=false
